# === LLM Configuration ===
LLM_PROVIDER=openai
# Options: openai, anthropic, openai_compatible
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_MAX_RETRIES=2
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_BASE_URL=https://api.openai.com/v1  # for openai_compatible

# === Database ===
DB_HOST=db
DB_PORT=5432
DB_NAME=ad_placement
DB_USER=agent
DB_PASSWORD=changeme

# === LangFuse ===
LANGFUSE_PUBLIC_KEY=pk-your-key
LANGFUSE_SECRET_KEY=sk-your-key
LANGFUSE_HOST=http://langfuse:3000  #или https://cloud.langfuse.com

NEXTAUTH_SECRET=my-super-secret-nextauth-key-12345
SALT=my-super-secret-salt-key-67890

# === App ===
LOG_LEVEL=INFO

# === SMTP (уведомления об ошибках) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
DEVELOPER_EMAIL=your-email@gmail.com

# === Автор модели ===
MODEL_AUTHOR_ID=dev_01